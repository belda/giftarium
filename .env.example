SECRET_KEY=your-secret-key-here
# DEBUG is forced True in development settings and False in production settings.
# Only set it here if you need to override for staging/testing.
# DEBUG=True

# Comma-separated list of hostnames that Django will serve, e.g.:
# ALLOWED_HOSTS=gifts.example.com,www.gifts.example.com
ALLOWED_HOSTS=localhost,127.0.0.1

# Comma-separated list of trusted origins for CSRF (must include scheme + host), e.g.:
# CSRF_TRUSTED_ORIGINS=https://gifts.example.com,https://www.gifts.example.com
CSRF_TRUSTED_ORIGINS=https://localhost

# Set to False if your reverse proxy (nginx, Traefik, Caddy) handles HTTPS termination
# and forwards plain HTTP internally to gunicorn:
# SECURE_SSL_REDIRECT=False

# Email — console backend is default (dev only); use smtp in production
DEFAULT_FROM_EMAIL=noreply@example.com
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# EMAIL_HOST=smtp.example.com
# EMAIL_PORT=587
# EMAIL_USE_TLS=True
# EMAIL_HOST_USER=
# EMAIL_HOST_PASSWORD=

# Google OAuth (optional)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

ADMIN_EMAIL=admin@example.com

# PostgreSQL (Docker / production)
DB_NAME=giftarium
DB_USER=postgres
DB_PASSWORD=changeme
DB_HOST=db
DB_PORT=5432
