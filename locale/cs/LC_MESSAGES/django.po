msgstr "Zkopírováno!"

msgid "Share your wishlist"
msgstr "Sdílet seznam přání"

#, python-format
msgid "Invite people to join <strong>%(name)s</strong>"
msgstr "Pozvěte ostatní do skupiny <strong>%(name)s</strong>"

