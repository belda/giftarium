# views.py flash messages
msgid "Create or join a group to see wishlists."
msgstr "Vytvořte nebo se připojte ke skupině pro zobrazení přání."

msgid "Please enter an email address."
msgstr "Zadejte prosím e-mailovou adresu."

#, python-format
msgid "%(email)s is already a member of this group."
msgstr "%(email)s je již členem této skupiny."

#, python-format
msgid "You've been invited to %(workspace)s on %(app)s"
msgstr "Byli jste pozváni do skupiny %(workspace)s v aplikaci %(app)s"

#, python-format
msgid "%(user)s has invited you to join \"%(workspace)s\" on %(app)s.\n\nAccept here: %(url)s"
msgstr "%(user)s vás zve do skupiny \"%(workspace)s\" v aplikaci %(app)s.\n\nPřijmout zde: %(url)s"

#, python-format
msgid "Invitation sent to %(email)s!"
msgstr "Pozvánka odeslána na %(email)s!"

msgid "Gift added to your wishlist!"
msgstr "Dárek přidán do vašeho seznamu přání!"

msgid "Gift updated!"
msgstr "Dárek byl upraven!"

msgid "Gift removed."
msgstr "Dárek byl odstraněn."

msgid "This user is not in your current group."
msgstr "Tento uživatel není ve vaší aktuální skupině."

#, python-format
msgid "Surprise gift added to %(name)s's wishlist!"
msgstr "Dárek překvapení přidán do seznamu přání uživatele %(name)s!"

msgid "Gift name is required."
msgstr "Název dárku je povinný."

msgid "Create or join a group first."
msgstr "Nejprve vytvořte nebo se připojte ke skupině."

msgid "Invalid date format."
msgstr "Neplatný formát data."

msgid "Profile updated!"
msgstr "Profil byl aktualizován!"

msgid "Invitation cancelled."
msgstr "Pozvánka byla zrušena."

#, python-format
msgid "You're already a member of %(name)s."
msgstr "Již jste členem skupiny %(name)s."

#, python-format
